# Copy this file to .env.local for local development:
#   cp .env.local.example .env.local
# Then also add every one of these in Vercel: Project → Settings → Environment Variables.

# ---- Supabase project (Dashboard → Project Settings → API) ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# ⚠️ Service role key = full admin access to your database & storage.
# Only ever set this as a SERVER-side env var (no NEXT_PUBLIC_ prefix).
# Never commit it, never log it, never send it to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ---- Admin back office login (pick your own values) ----
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-to-a-strong-password
# Any long random string, e.g. generate one with: openssl rand -base64 32
ADMIN_SESSION_SECRET=replace-with-a-long-random-string
